PORT=3001
STORAGE_PATH=./storage
DB_PATH=./liftiq.db

# Required for the diagnostic funnel's web-search feature.
# Without this, /api/search returns 503 and the funnel still works
# (just no live web results). Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

